{$APP_DOMAIN} {
    header {
        Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-ZswfTY7H35rbv8WC7NXBoiC7WNu86vSzCDChNWwZZDM=' 'sha256-ToofGf2BXRDHNF7a2CHmKNhiRx3S29xnXxJbpkbzh8Y='; style-src 'self' 'unsafe-inline'; img-src 'self' https:;"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
        -Via
    }
    
    handle /api/* {
        reverse_proxy api:8080 {
            header_up X-Forwarded-For {remote_host}
        }
    }

    handle /hangfire* {
        reverse_proxy api:8080 {
            header_up X-Forwarded-For {remote_host}
        }
    }

    handle /swagger* {
        reverse_proxy api:8080
    }

    handle {
        reverse_proxy frontend:80
    }
}
